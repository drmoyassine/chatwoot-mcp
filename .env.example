# ─── Dashboard Admin Credentials (Required) ───
ADMIN_EMAIL=admin@mcphub.local
ADMIN_PASSWORD=change_me_please
JWT_SECRET=generate_a_random_64_char_hex_string

# ─── Chatwoot Configuration (Optional — can be set via Dashboard UI) ───
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your_chatwoot_api_access_token
CHATWOOT_ACCOUNT_ID=1

# ─── MongoDB ───
MONGO_URL=mongodb://localhost:27017
DB_NAME=chatwoot_mcp

# ─── Server ───
CORS_ORIGINS=*
